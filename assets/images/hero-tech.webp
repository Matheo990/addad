<?xml version="1.0" encoding="UTF-8"?>
<svg width="600" height="400" viewBox="0 0 600 400" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Arrière-plan dégradé -->
  <defs>
    <linearGradient id="heroGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3B82F6;stop-opacity:0.1"/>
      <stop offset="100%" style="stop-color:#1D4ED8;stop-opacity:0.2"/>
    </linearGradient>
  </defs>
  
  <rect width="600" height="400" fill="url(#heroGradient)"/>
  
  <!-- Dispositifs technologiques stylisés -->
  
  <!-- Smartphone -->
  <g transform="translate(100, 80)">
    <rect x="0" y="0" width="60" height="120" rx="12" fill="#1F2937" stroke="#374151" stroke-width="2"/>
    <rect x="8" y="15" width="44" height="78" rx="4" fill="#3B82F6"/>
    <circle cx="30" cy="105" r="6" fill="#6B7280"/>
    <!-- Icônes d'apps -->
    <rect x="12" y="20" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
    <rect x="24" y="20" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
    <rect x="36" y="20" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
  </g>
  
  <!-- Ordinateur portable -->
  <g transform="translate(300, 120)">
    <rect x="0" y="30" width="120" height="80" rx="8" fill="#1F2937"/>
    <rect x="8" y="15" width="104" height="65" rx="4" fill="#111827"/>
    <rect x="12" y="20" width="96" height="54" rx="2" fill="#3B82F6"/>
    <rect x="48" y="85" width="24" height="4" rx="2" fill="#6B7280"/>
    <!-- Clavier stylisé -->
    <rect x="16" y="95" width="88" height="20" rx="4" fill="#374151"/>
  </g>
  
  <!-- Console de jeu -->
  <g transform="translate(480, 150)">
    <rect x="0" y="0" width="80" height="50" rx="8" fill="#1F2937"/>
    <rect x="8" y="8" width="64" height="34" rx="4" fill="#111827"/>
    <!-- Contrôleurs -->
    <circle cx="20" cy="25" r="4" fill="#3B82F6"/>
    <circle cx="60" cy="25" r="4" fill="#F59E0B"/>
    <rect x="35" y="15" width="10" height="4" rx="2" fill="#6B7280"/>
    <rect x="35" y="31" width="10" height="4" rx="2" fill="#6B7280"/>
  </g>
  
  <!-- Écouteurs -->
  <g transform="translate(200, 50)">
    <circle cx="0" cy="0" r="20" fill="#1F2937"/>
    <circle cx="50" cy="0" r="20" fill="#1F2937"/>
    <path d="M20 -5 Q 35 -15 50 -5" stroke="#374151" stroke-width="4" fill="none"/>
    <circle cx="0" cy="0" r="12" fill="#3B82F6"/>
    <circle cx="50" cy="0" r="12" fill="#3B82F6"/>
  </g>
  
  <!-- Éléments décoratifs -->
  <circle cx="50" cy="300" r="3" fill="#3B82F6" opacity="0.6"/>
  <circle cx="550" cy="100" r="4" fill="#F59E0B" opacity="0.6"/>
  <circle cx="450" cy="350" r="2" fill="#10B981" opacity="0.6"/>
  <circle cx="150" cy="350" r="3" fill="#8B5CF6" opacity="0.6"/>
  
  <!-- Lignes de connexion futuristes -->
  <path d="M100 200 Q 300 180 500 220" stroke="#3B82F6" stroke-width="2" fill="none" opacity="0.3"/>
  <path d="M200 100 Q 350 120 480 170" stroke="#F59E0B" stroke-width="1" fill="none" opacity="0.4"/>
  
  <!-- Texte placeholder -->
  <text x="300" y="350" text-anchor="middle" font-family="Inter, sans-serif" font-size="24" font-weight="600" fill="#1F2937" opacity="0.8">
    Innovation Tech
  </text>
</svg>