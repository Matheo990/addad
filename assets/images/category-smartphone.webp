<?xml version="1.0" encoding="UTF-8"?>
<svg width="300" height="200" viewBox="0 0 300 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="phoneBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F9FAFB"/>
      <stop offset="100%" style="stop-color:#E5E7EB"/>
    </linearGradient>
  </defs>
  
  <rect width="300" height="200" fill="url(#phoneBg)"/>
  
  <!-- Smartphone principal -->
  <g transform="translate(120, 30)">
    <rect x="0" y="0" width="60" height="140" rx="12" fill="#1F2937" stroke="#374151" stroke-width="2"/>
    <rect x="6" y="20" width="48" height="100" rx="4" fill="#3B82F6"/>
    <circle cx="30" cy="15" r="2" fill="#6B7280"/>
    <circle cx="30" cy="130" r="4" fill="#6B7280"/>
    
    <!-- Interface utilisateur -->
    <rect x="10" y="25" width="40" height="6" rx="3" fill="white" opacity="0.9"/>
    <rect x="10" y="35" width="20" height="4" rx="2" fill="white" opacity="0.7"/>
    <rect x="34" y="35" width="16" height="4" rx="2" fill="white" opacity="0.7"/>
    
    <!-- Grille d'icônes -->
    <rect x="12" y="45" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
    <rect x="24" y="45" width="8" height="8" rx="2" fill="#F59E0B" opacity="0.8"/>
    <rect x="36" y="45" width="8" height="8" rx="2" fill="#10B981" opacity="0.8"/>
    <rect x="48" y="45" width="8" height="8" rx="2" fill="#EF4444" opacity="0.8"/>
    
    <rect x="12" y="57" width="8" height="8" rx="2" fill="#8B5CF6" opacity="0.8"/>
    <rect x="24" y="57" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
    <rect x="36" y="57" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
    <rect x="48" y="57" width="8" height="8" rx="2" fill="white" opacity="0.8"/>
  </g>
  
  <!-- Smartphone secondaire (arrière-plan) -->
  <g transform="translate(70, 50) rotate(-15)" opacity="0.6">
    <rect x="0" y="0" width="50" height="120" rx="10" fill="#374151"/>
    <rect x="5" y="15" width="40" height="90" rx="3" fill="#6B7280"/>
  </g>
  
  <!-- Smartphone tertiaire (arrière-plan) -->
  <g transform="translate(170, 60) rotate(15)" opacity="0.6">
    <rect x="0" y="0" width="50" height="120" rx="10" fill="#374151"/>
    <rect x="5" y="15" width="40" height="90" rx="3" fill="#6B7280"/>
  </g>
  
  <!-- Éléments décoratifs -->
  <circle cx="50" cy="50" r="2" fill="#3B82F6" opacity="0.4"/>
  <circle cx="250" cy="150" r="3" fill="#F59E0B" opacity="0.4"/>
  <circle cx="30" cy="170" r="1" fill="#10B981" opacity="0.6"/>
</svg>