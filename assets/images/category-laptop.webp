<?xml version="1.0" encoding="UTF-8"?>
<svg width="300" height="200" viewBox="0 0 300 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="laptopBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F3F4F6"/>
      <stop offset="100%" style="stop-color:#D1D5DB"/>
    </linearGradient>
  </defs>
  
  <rect width="300" height="200" fill="url(#laptopBg)"/>
  
  <!-- Ordinateur portable principal -->
  <g transform="translate(50, 50)">
    <!-- Base du laptop -->
    <rect x="0" y="80" width="200" height="120" rx="12" fill="#1F2937"/>
    <rect x="8" y="60" width="184" height="110" rx="8" fill="#111827"/>
    <rect x="12" y="65" width="176" height="98" rx="4" fill="#3B82F6"/>
    
    <!-- Écran -->
    <rect x="16" y="70" width="168" height="88" rx="2" fill="#111827"/>
    <rect x="20" y="74" width="160" height="80" rx="2" fill="#374151"/>
    
    <!-- Interface sur l'écran -->
    <rect x="30" y="84" width="140" height="8" rx="4" fill="#3B82F6" opacity="0.8"/>
    <rect x="30" y="98" width="60" height="4" rx="2" fill="white" opacity="0.6"/>
    <rect x="95" y="98" width="75" height="4" rx="2" fill="white" opacity="0.6"/>
    
    <!-- Fenêtres d'application -->
    <rect x="30" y="108" width="50" height="35" rx="3" fill="#F59E0B" opacity="0.7"/>
    <rect x="85" y="108" width="50" height="35" rx="3" fill="#10B981" opacity="0.7"/>
    <rect x="140" y="108" width="30" height="35" rx="3" fill="#EF4444" opacity="0.7"/>
    
    <!-- Clavier -->
    <rect x="20" y="170" width="160" height="25" rx="4" fill="#374151"/>
    <!-- Touches du clavier -->
    <rect x="25" y="174" width="8" height="6" rx="1" fill="#6B7280"/>
    <rect x="36" y="174" width="8" height="6" rx="1" fill="#6B7280"/>
    <rect x="47" y="174" width="8" height="6" rx="1" fill="#6B7280"/>
    <rect x="58" y="174" width="8" height="6" rx="1" fill="#6B7280"/>
    
    <!-- Trackpad -->
    <rect x="85" y="182" width="30" height="20" rx="3" fill="#4B5563"/>
  </g>
  
  <!-- Éléments décoratifs -->
  <circle cx="30" cy="30" r="2" fill="#3B82F6" opacity="0.5"/>
  <circle cx="270" cy="40" r="3" fill="#F59E0B" opacity="0.5"/>
  <circle cx="20" cy="180" r="1" fill="#10B981" opacity="0.7"/>
  <circle cx="280" cy="170" r="2" fill="#8B5CF6" opacity="0.5"/>
</svg>